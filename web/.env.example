# Neon PostgreSQL connection string (get from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/cyprus_rental?sslmode=require

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here

# NextAuth.js URL (your Vercel deployment URL)
NEXTAUTH_URL=https://your-app.vercel.app

# GitHub (for triggering scrape from dashboard)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo
GITHUB_CRAWL_WORKFLOW=crawl.yml
